<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <!-- Fija y aislada de apps/api/.env (que además ya no está vacío,
             corregido por separado) — evita que los tests dependan del
             estado local del .env de cada desarrollador. -->
        <env name="APP_KEY" value="base64:n1c3g/oFtYjOAD8ocRfG8/2NadWw7l6kQwnXgAuFcr8="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- El proyecto usa PostgreSQL exclusivamente, sin excepción para
             tests (SQLite queda descartado: divergía de sintaxis/constraints
             reales de Postgres y ya causó una migración incompatible). Los
             tests corren contra una base de datos Postgres SEPARADA de la de
             desarrollo (vocare_test vs vocare) en el mismo contenedor
             `postgres`, provista por infra/postgres/init-test-db.sql. -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="postgres"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="vocare_test"/>
        <env name="DB_USERNAME" value="vocare"/>
        <env name="DB_PASSWORD" value="vocare_secret"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
